# ─────────────────────────────────────────────────────────────────────────────
# SecureBank Frontend — Vite environment variables
#
# Copy this file to .env and fill in the values before running locally.
#   cp .env.example .env
#
# All variables MUST start with VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the SecureBank API.
# For local dev this points at the Express server running on port 3000.
# In production the ALB routes /api/* to the backend so the value becomes
# the ALB domain (e.g. https://securebank.example.com).
VITE_API_BASE_URL=http://localhost:3000/v1
