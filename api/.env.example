# ─────────────────────────────────────────────────────────────────────────────
# SecureBank API — environment variables
#
# Copy to .env for local development:  cp .env.example .env
# In production (Render) these are set on the service, NOT committed to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Render Postgres in prod, local Postgres in dev) ──────────────────
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://securebank:changeme@localhost:5432/securebank
# Set to "true" when connecting to a managed Postgres that requires TLS
# (e.g. Render's EXTERNAL connection string). Leave false for the internal URL.
DATABASE_SSL=false

# ── Redis (Render Key Value in prod) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT signing keys (RS256) ──────────────────────────────────────────────────
# Generate a fresh pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM contents (newlines may be stored as \n).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── AES-256-GCM key (encrypts PAN / Aadhaar fields) ──────────────────────────
# Exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_256_KEY=

# ── OTP delivery ──────────────────────────────────────────────────────────────
# "console" prints the login OTP to the server logs (no SMS/email provider
# needed). Anything else uses AWS SNS (requires AWS credentials + SNS_TOPIC_ARN).
OTP_DELIVERY=console

# ── Starter account seed (used by `npm run seed`) ────────────────────────────
SEED_USERNAME=customer1
SEED_PASSWORD=ChangeMe@123
# Optional:
# SEED_EMAIL=customer1@securebank.local
# SEED_PHONE=+910000000000
# SEED_SAMPLE_DATA=true

# ── AWS (only if you opt back into Secrets Manager / SNS / CloudWatch) ────────
# USE_AWS_SECRETS=false      # true -> fetch JWT/AES/etc. from Secrets Manager
# CLOUDWATCH_ENABLED=false   # true -> publish custom metrics to CloudWatch
# SNS_TOPIC_ARN=
# AWS_REGION=ap-south-1

# ── CORS (only if the frontend is served from a different origin) ────────────
# Not needed when the API serves the built frontend (default deploy).
# CORS_ORIGIN=https://your-frontend.example.com
